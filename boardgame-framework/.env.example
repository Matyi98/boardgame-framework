# === Postgres ===
POSTGRES_USER=bgf
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bgf

# === Redis ===
REDIS_URL=redis://redis:6379

# === RabbitMQ ===
RABBITMQ_DEFAULT_USER=bgf
RABBITMQ_DEFAULT_PASS=changeme
RABBITMQ_URL=amqp://bgf:changeme@rabbitmq:5672

# === JWT ===
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# === Service ports (inside docker network) ===
AUTH_PORT=3001
LOBBY_PORT=3002
REALTIME_PORT=3003
ENGINE_PORT=3004
